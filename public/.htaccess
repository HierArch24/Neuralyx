# ---- CloudLinux Passenger (NEURALYX MCP server, Node) ----
# /api/* requests are routed to the mcp-server Passenger app at
# /home/devenvir/neuralyx-mcp. This block must come BEFORE any RewriteRule,
# otherwise the SPA fallback captures /api/* and returns index.html.
PassengerAppRoot "/home/devenvir/neuralyx-mcp"
PassengerBaseURI "/api"
PassengerNodejs "/opt/alt/alt-nodejs22/root/usr/bin/node"
PassengerAppType node
PassengerStartupFile app.js

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Skip rewrite for API routes — Passenger Node app handles them
  RewriteCond %{REQUEST_URI} ^/api(/|$)
  RewriteRule ^ - [L]

  # Skip rewrite for actual files and directories
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Skip rewrite for asset files (videos, images, fonts, etc.)
  RewriteRule \.(mp4|webm|mov|jpg|jpeg|png|gif|svg|ico|woff2?|ttf|eot|pdf|css|js|json|wasm)$ - [L]

  # GitNexus sub-app routing
  RewriteCond %{REQUEST_URI} ^/gitnexus/
  RewriteRule ^gitnexus/(.*)$ /gitnexus/index.html [L]

  # SPA routing - everything else goes to index.html
  RewriteRule ^ /index.html [L]
</IfModule>

# Proper MIME types
AddType video/mp4 .mp4
AddType video/webm .webm
AddType video/ogg .ogv
AddType application/wasm .wasm
AddType application/json .json

# Gzip compression (exclude video/images)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/json application/javascript text/xml application/xml text/javascript image/svg+xml
</IfModule>

# Cache headers
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType video/mp4 "access plus 7 days"
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-Content-Type-Options "nosniff"
  Header set X-XSS-Protection "1; mode=block"
</IfModule>
