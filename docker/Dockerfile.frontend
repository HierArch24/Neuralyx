# Stage 1: Build NEURALYX
FROM node:20-alpine AS builder
WORKDIR /app

ARG VITE_SUPABASE_URL
ARG VITE_SUPABASE_ANON_KEY
ARG VITE_MCP_SERVER_URL
ARG VITE_OPENAI_KEY

ENV VITE_SUPABASE_URL=$VITE_SUPABASE_URL
ENV VITE_SUPABASE_ANON_KEY=$VITE_SUPABASE_ANON_KEY
ENV VITE_MCP_SERVER_URL=$VITE_MCP_SERVER_URL
ENV VITE_OPENAI_KEY=$VITE_OPENAI_KEY

COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

# Stage 2: Build GitNexus (same-origin for DOM access)
FROM node:20-alpine AS gitnexus-builder
RUN apk add --no-cache git
WORKDIR /gitnexus
RUN git clone --depth 1 https://github.com/nxpatterns/gitnexus.git . \
    && cd gitnexus-web \
    && npm ci \
    && npm run build

# Stage 3: Serve
FROM nginx:alpine
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html
COPY --from=gitnexus-builder /gitnexus/gitnexus-web/dist /usr/share/nginx/html/gitnexus
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
